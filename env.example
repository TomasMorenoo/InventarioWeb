# ==================== FLASK ====================
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=tu_clave_secreta_aqui

# ==================== SERVER ====================
FLASK_HOST=tu_host_aqui
FLASK_PORT=5000

# ==================== BASES DE DATOS ====================
SHARED_DB_SERVER=tu_servidor_db
SHARED_DB_PATH=\\ruta\compartida\db
INVENTARIO_DB=\\ruta\compartida\db\inventarioWeb\inventario_computadoras.db
OFICINAS_CNE_DB=\\ruta\compartida\db\oficinasCne.db
IMPRESORAS_DB=\\ruta\compartida\db\inventarioWeb\impresoras.db
NOTEBOOKS_DB=\\ruta\compartida\db\inventarioWeb\inventario_notebooks.db

# ==================== BASES DE DATOS LOCALES ====================
LOCAL_DB_DIR=./db
DB_TIMEOUT=5

# ==================== SESIÓN Y LOGGING ====================
SESSION_LIFETIME_HOURS=24
SESSION_COOKIE_SECURE=False
LOG_LEVEL=DEBUG

# ==================== EXPORTACIÓN ====================
EXPORT_DIR=./exports
MAX_CONTENT_LENGTH=16777216

# ==================== PAGINACIÓN ====================
ITEMS_PER_PAGE=50

# ==================== FEATURE FLAGS ====================
ENABLE_API=True
ENABLE_DEBUG_ROUTES=True
ENABLE_EXPORT=True
